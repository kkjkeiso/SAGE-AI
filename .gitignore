# ================================
# SAGE AI — .gitignore
# Ignora artefatos de build, dados sensíveis e configurações de IDE
# ================================

# ---------- Dados sensíveis ----------
# Nunca commitar arquivos com chaves de API ou credenciais
.env
*.env
.env.*
application-*.properties
!application.properties

# ---------- Backend (Java / Maven) ----------
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.jar
backend/*.war

# ---------- Dependências e cache ----------
node_modules/
.cache/
*.log

# ---------- IDEs ----------
.vscode/
.idea/
*.iws
*.iml
*.ipr
.project
.classpath
.settings/
.factorypath
.apt_generated
.springBeans
.sts4-cache
*.swp
*.swo
*~

# ---------- Sistema operacional ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Gemini / Antigravity ----------
.gemini/
